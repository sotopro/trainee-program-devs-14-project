# Connection string para la base de datos (Prisma Postgres).
# Obten la tuya desde https://console.prisma.io/ -> tu proyecto -> Development -> Connect.
# Formato tipico: postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require
DATABASE_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"
