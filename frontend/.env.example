# URL base del backend (sin trailing slash)
VITE_API_URL=http://localhost:3000

# Entorno de ejecucion: development | staging | production
VITE_APP_ENV=development

# Habilita/deshabilita funcionalidades de IA (no almacenar keys aqui)
VITE_OPENAI_ENABLED=false

# Activa logs de depuracion en consola
VITE_DEBUG=false